generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider =  "postgresql"
  url      =  env("DATABASE_URL")
}

// 1. 8 Fundamental Habit Categories
model HabitCategory {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  
  // Relation to PlannedAction: A category can have many planned actions
  plans       PlannedAction[] 

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// 2. The 31-Day Sprint
model Cycle {
  id        String     @id @default(uuid())
  startDate DateTime   @default(now())
  endDate   DateTime
  isActive  Boolean    @default(true)
  
  // Relation: A cycle has many days (exactly 31)
  logs      DailyLog[] 
  
  userId    String
  user      User       @relation(fields: [userId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// 3. The Daily Log
model DailyLog {
  id        String          @id @default(uuid())
  date      DateTime        @default(now())
  isClosed  Boolean         @default(false) 
  
  cycleId   String
  cycle     Cycle           @relation(fields: [cycleId], references: [id])
  
  // Relation: A day has the planned tasks from the previous night
  plans     PlannedAction[] 

  userId    String
  user      User            @relation(fields: [userId], references: [id])
  
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// 4. The Planned Action (The specific goal written by the user)
model PlannedAction {
  id          String        @id @default(uuid())
  description String        
  isCompleted Boolean       @default(false)
  
  logId       String
  dailyLog    DailyLog      @relation(fields: [logId], references: [id])
  
  categoryId  String
  category    HabitCategory @relation(fields: [categoryId], references: [id])

  userId      String
  user        User          @relation(fields: [userId], references: [id])
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// 5. The User
model User {
  id              String      @id @default(uuid())
  email           String      @unique
  hashedPassword  String

  // Relations
  cycles          Cycle[]
  logs            DailyLog[]
  plans           PlannedAction[]

  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}